generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Post {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  authorId  String?
  // O @map liga o nome do TS ao nome da coluna no Postgres
  createdAt DateTime @default(now()) @map("created_at")

  @@map("Post")
}

model Comment {
  id         Int      @id @default(autoincrement())
  content    String
  
  // Mapeia o nome do banco (post_id) para o nome no código (postId)
  postId     Int      @map("post_id")
  
  // Mapeia o nome do banco (created_at) para o nome no código (createdAt)
  createdAt  DateTime @default(now()) @map("created_at")

  // Relação com o modelo Post (certifique-se que o campo de relação aponte para postId)
  post       Post     @relation(fields: [postId], references: [id])

  @@map("Comment")
}

enum Role {
  USER
  ADMIN
  MODERATOR
}

model User {
  id         String   @id // UUID do Supabase
  email      String   @unique
  name       String?  // Opcional para OAuth
  avatarUrl  String?  // Opcional para OAuth
  role       Role     @default(USER)
  createdAt  DateTime @default(now())
}
