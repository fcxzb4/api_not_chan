generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Post {
  id Int @id @default(autoincrement())

  title     String
  content   String
  createdAt DateTime  @default(now())

  comments  Comment[]
}

model Comment {
  id Int @id @default(autoincrement())

  content   String
  createdAt DateTime  @default(now()) @map("created_at")

  postId    Int
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

 @@map("Comment")// Força o nome exato da tabela no Supabase
}

enum Role {
  USER
  ADMIN
  MODERATOR
}

model User {
  id         String   @id // UUID do Supabase
  email      String   @unique
  name       String?  // Opcional para OAuth
  avatarUrl  String?  // Opcional para OAuth
  role       Role     @default(USER)
  createdAt  DateTime @default(now())
}
